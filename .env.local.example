# Local developer configuration. Copy to `.env.local` and edit for your machine.
# `.env.local` is intentionally ignored by Git.

# Backend browser smoke. Keep this server-only; do not expose it through NEXT_PUBLIC_*.
MAINTENANCE_PLANNING_API_URL=http://127.0.0.1:5000
MAINTENANCE_PLANNING_API_TOKEN=local-reviewer-token

# Baseline deterministic simulator scenario horizon.
MAINTENANCE_PLANNING_WEB_BACKEND_HORIZON_START_UTC=2026-01-16T00:00:00Z
MAINTENANCE_PLANNING_WEB_BACKEND_HORIZON_END_UTC=2026-01-30T00:00:00Z
MAINTENANCE_PLANNING_WEB_BACKEND_REQUESTED_BY=planner-workbench-e2e

# Local Playwright workbench port for backend smoke.
MP_PLAYWRIGHT_BACKEND_PORT=3101
