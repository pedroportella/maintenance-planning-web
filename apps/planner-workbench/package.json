{
  "name": "@maintenance-planning/planner-workbench",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Next.js planner workbench for synthetic maintenance-planning review flows.",
  "scripts": {
    "build": "next build",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "dev": "next dev --hostname 127.0.0.1 --port 3100",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@maintenance-planning/services": "workspace:*",
    "@maintenance-planning/ui-assets": "workspace:*",
    "@maintenance-planning/ui-library": "workspace:*",
    "@maintenance-planning/utils": "workspace:*",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "sass": "^1.101.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
