{
  "name": "maintenance-planning-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/workspace-runner.mjs build",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "guard": "node scripts/quality-guards.mjs all",
    "guard:artifacts": "node scripts/quality-guards.mjs artifacts",
    "guard:browser-origins": "node scripts/quality-guards.mjs browser-origins",
    "guard:public-docs": "node scripts/quality-guards.mjs public-docs",
    "guard:secrets": "node scripts/quality-guards.mjs secrets",
    "lint": "node scripts/workspace-runner.mjs lint",
    "test": "node scripts/workspace-runner.mjs test",
    "test:e2e:mock": "node scripts/run-playwright.mjs test --config playwright.config.mjs",
    "test:links": "node scripts/markdown-link-check.mjs",
    "test:reviewer-evidence": "node scripts/reviewer-evidence-smoke.mjs",
    "typecheck": "node scripts/workspace-runner.mjs typecheck",
    "verify": "pnpm guard && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:reviewer-evidence"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/react": "19.2.17"
  },
  "packageManager": "pnpm@10.18.3"
}
